    {
      "path": "/api/affiliate/cron/refresh-links",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/perplexity-scheduler",
      "schedule": "10 */2 * * *"
    },
    {
      "path": "/api/cron/perplexity-executor",
      "schedule": "20,50 * * * *"
    },
    {
      "path": "/api/cron/data-refresh",
